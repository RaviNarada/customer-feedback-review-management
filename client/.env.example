# ==============================================================================
# CLIENT ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to .env and fill in the values

# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000

# Application Configuration
VITE_APP_NAME=Customer Feedback Review Management
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false

# Environment
VITE_NODE_ENV=development

# Authentication
VITE_AUTH_TOKEN_KEY=auth_token
VITE_AUTH_REFRESH_TOKEN_KEY=refresh_token

# Dashboard Configuration
VITE_DASHBOARD_REFRESH_INTERVAL=30000
VITE_PAGE_SIZE=20

# Sentiment Analysis
VITE_SENTIMENT_THRESHOLD_POSITIVE=0.7
VITE_SENTIMENT_THRESHOLD_NEGATIVE=0.3

# Development
VITE_DEBUG=false
VITE_LOG_LEVEL=info
